GITHUB_USER=NikolayS
GITHUB_TOKEN=ghp_your_token_here

# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5

# API key for Anthropic or OpenAI
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OPENAI_API_KEY=sk-your_key_here

# For Ollama (optional, defaults to http://localhost:11434)
# LLM_BASE_URL=http://localhost:11434

# Newspaper title
GITZETTE_TITLE=the changelog

# Fork repos to include open WIP PRs from (comma-separated owner/repo)
GITZETTE_FORKS=NikolayS/postgres,NikolayS/pg-flight-recorder,NikolayS/pg_wait_tracer

# LinkedIn scraping (your own profile)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_password_here

# Twitter/X scraping (public profile, no login needed for public accounts)
TWITTER_USER=samokhvalov
# TWITTER_COOKIES_FILE=.twitter-cookies.json  # optional, for logged-in scraping
